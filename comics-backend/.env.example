# Server
PORT=5000

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:<MẬT_KHẨU>@localhost:5432/comics_db

# JWT
JWT_SECRET=

# SMTP (Gmail) — Use App Password, not your regular password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Google OAuth 2.0
GOOGLE_CLIENT_ID=

# MoMo Payment
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_CREATE_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
# MOMO_IPN_URL must be a public https URL (use ngrok when developing locally)
MOMO_IPN_URL=
# Redirect about FE after payment
MOMO_REDIRECT_URL=http://localhost:5173/profile

# Cloudinary (save cover art, chapter images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
